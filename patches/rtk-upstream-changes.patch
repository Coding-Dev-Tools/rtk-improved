+// ─── Command Code CLI support ────────────────────────────────────────
+
+pub fn run_commandcode_mode(global: bool, ctx: InitContext) -> Result<()> {
+    let commandcode_dir = if global {
+        resolve_home_subdir(COMMANDCODE_DIR)?
+    } else {
+        PathBuf::from(COMMANDCODE_DIR)
+    };
+    run_commandcode_mode_at(&commandcode_dir, global, ctx)
+}
+
+fn run_commandcode_mode_at(dir: &Path, global: bool, ctx: InitContext) -> Result<()> {
+    let InitContext { dry_run, .. } = ctx;
+
+    let ref_dir = dir.join(COMMANDCODE_REFERENCES_SUBDIR);
+    if !dry_run {
+        fs::create_dir_all(&ref_dir).with_context(|| {
+            format!("Failed to create reference dir: {}", ref_dir.display())
+        })?;
+    }
+
+    let agents_path = dir.join(COMMANDCODE_AGENTS_FILE);
+    let commands_path = ref_dir.join(COMMANDCODE_COMMANDS_REF);
+    let analytics_path = ref_dir.join(COMMANDCODE_ANALYTICS_REF);
+
+    write_if_changed(
+        &agents_path,
+        RTK_SLIM_COMMANDCODE,
+        "Command Code AGENTS.md",
+        ctx,
+    )?;
+    write_if_changed(
+        &commands_path,
+        COMMANDCODE_COMMANDS_CONTENT,
+        "Command Code commands reference",
+        ctx,
+    )?;
+    write_if_changed(
+        &analytics_path,
+        COMMANDCODE_ANALYTICS_CONTENT,
+        "Command Code analytics reference",
+        ctx,
+    )?;
+
+    if !dry_run {
+        println!("\nRTK configured for Command Code CLI.\n");
+        println!("  AGENTS.md:  {}", agents_path.display());
+        println!("  References: {}/", ref_dir.display());
+        if global {
+            println!("\n  Command Code CLI reads ~/.commandcode/AGENTS.md automatically.");
+        } else {
+            println!("\n  Command Code CLI reads .commandcode/AGENTS.md from the project root.");
+        }
+        println!("  Restart Command Code. Test with: git status\n");
+    }
+
+    Ok(())
+}
+
+pub fn uninstall_commandcode(global: bool, ctx: InitContext) -> Result<()> {
+    let InitContext { verbose, dry_run } = ctx;
+    let dir = if global {
+        resolve_home_subdir(COMMANDCODE_DIR)?
+    } else {
+        PathBuf::from(COMMANDCODE_DIR)
+    };
+
+    let agents_path = dir.join(COMMANDCODE_AGENTS_FILE);
+    let ref_dir = dir.join(COMMANDCODE_REFERENCES_SUBDIR);
+
+    let mut removed = Vec::new();
+
+    if agents_path.exists() {
+        if dry_run {
+            println!("[dry-run] would remove {}", agents_path.display());
+        } else {
+            fs::remove_file(&agents_path)
+                .with_context(|| format!("Failed to remove {}", agents_path.display()))?;
+            if verbose > 0 {
+                eprintln!("Removed {}", agents_path.display());
+            }
+        }
+        removed.push(agents_path.display().to_string());
+    }
+
+    if ref_dir.exists() {
+        if dry_run {
+            println!("[dry-run] would remove {}/", ref_dir.display());
+        } else {
+            fs::remove_dir_all(&ref_dir)
+                .with_context(|| format!("Failed to remove {}/", ref_dir.display()))?;
+            if verbose > 0 {
+                eprintln!("Removed {}/", ref_dir.display());
+            }
+        }
+        removed.push(format!("{}/", ref_dir.display()));
+    }
+
+    if removed.is_empty() {
+        println!("RTK Command Code support was not installed (nothing to remove)");
+    } else {
+        let header = if dry_run {
+            "[dry-run] would uninstall RTK for Command Code CLI:"
+        } else {
+            "RTK uninstalled for Command Code CLI:"
+        };
+        println!("{}", header);
+        for item in removed {
+            println!("  - {}", item);
+        }
+    }
+
+    Ok(())
+}
